<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/perm_gate_title"
            android:textAppearance="@style/TextAppearance.VanillaPay.Title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/perm_gate_subtitle"
            android:textAppearance="@style/TextAppearance.VanillaPay.Body" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.VanillaPay.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/card_padding"
                android:paddingEnd="@dimen/card_padding">

                <!-- Notification listener -->
                <LinearLayout
                    android:id="@+id/rowNotif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bell" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/perm_notif"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/perm_notif_desc"
                            android:textAppearance="@style/TextAppearance.VanillaPay.Label" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNotifState"
                        style="@style/Widget.VanillaPay.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill"
                        android:backgroundTint="@color/warning_container"
                        android:text="@string/perm_off"
                        android:textColor="@color/warning" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border" />

                <!-- Battery optimization -->
                <LinearLayout
                    android:id="@+id/rowBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_battery" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/perm_battery"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/perm_battery_desc"
                            android:textAppearance="@style/TextAppearance.VanillaPay.Label" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBatteryState"
                        style="@style/Widget.VanillaPay.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill"
                        android:backgroundTint="@color/warning_container"
                        android:text="@string/perm_off"
                        android:textColor="@color/warning" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border" />

                <!-- Autostart -->
                <LinearLayout
                    android:id="@+id/rowAutostart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_power" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/perm_autostart"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/perm_autostart_desc"
                            android:textAppearance="@style/TextAppearance.VanillaPay.Label" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAutostartState"
                        style="@style/Widget.VanillaPay.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill"
                        android:backgroundTint="@color/warning_container"
                        android:text="@string/perm_off"
                        android:textColor="@color/warning" />
                </LinearLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbAutostart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:text="@string/perm_autostart_confirm"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnter"
            style="@style/Widget.VanillaPay.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2xl"
            android:enabled="false"
            android:text="@string/perm_gate_enter" />

    </LinearLayout>
</ScrollView>
