<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============ Text appearances ============ -->
    <style name="TextAppearance.VanillaPay.Amount" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_amount</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.VanillaPay.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VanillaPay.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.VanillaPay.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="TextAppearance.VanillaPay.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- ============ Buttons ============ -->
    <style name="Widget.VanillaPay.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.VanillaPay.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.VanillaPay.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="iconTint">@color/brand_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ============ Cards ============ -->
    <style name="Widget.VanillaPay.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="android:checkable">false</item>
    </style>

    <!-- ============ Inputs ============ -->
    <style name="Widget.VanillaPay.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/button_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/button_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/button_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/button_radius</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <!-- ============ Badge (status pill) ============ -->
    <style name="Widget.VanillaPay.Badge" parent="">
        <item name="android:paddingStart">@dimen/space_sm</item>
        <item name="android:paddingEnd">@dimen/space_sm</item>
        <item name="android:paddingTop">@dimen/space_xs</item>
        <item name="android:paddingBottom">@dimen/space_xs</item>
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
