<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Full-bleed art lives in the BACKGROUND so launchers that shrink the adaptive
         foreground (MIUI/HyperOS) can't create an inner-square seam. -->
    <background android:drawable="@drawable/ic_launcher_bg" />
    <foreground android:drawable="@android:color/transparent" />
    <monochrome android:drawable="@drawable/ic_notification_vanillapay" />
</adaptive-icon>
